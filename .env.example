# ============================================
# WazuhBOTS — Environment Configuration
# ============================================
# Copy this file to .env and customize values
# Passwords will be auto-generated by setup.sh

# --- Wazuh Indexer ---
INDEXER_PASSWORD=ChangeMeIndexer123!
INDEXER_HEAP=2g

# --- Wazuh Dashboard ---
DASHBOARD_PASSWORD=ChangeMeDashboard123!

# --- Wazuh API ---
API_USERNAME=wazuh-wui
API_PASSWORD=ChangeMeAPI123!

# --- CTFd ---
CTFD_SECRET_KEY=ChangeMeCTFdSecret!
CTFD_DB_PASSWORD=ChangeMeDB123!
CTFD_DB_ROOT_PASSWORD=ChangeMeDBRoot123!

# --- Competition Settings ---
COMPETITION_NAME=WazuhBOTS
COMPETITION_MODE=competition
# Modes: training, competition, self-guided, public
COMPETITION_DURATION_HOURS=4

# --- Network ---
SUBNET=172.26.0.0/24
DOMAIN=wazuhbots.local

# --- Participant Read-Only Credentials ---
PARTICIPANT_USER=analyst
PARTICIPANT_PASSWORD=WazuhBOTS2026!
